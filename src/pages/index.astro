---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="FairMed International — Medical Equipment. Fair Prices.">

  <!-- NAVIGATION -->
  <nav class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur-sm z-50 border-b border-light">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="#" class="font-serif font-bold text-xl tracking-tight">FairMed</a>
      <div class="hidden md:flex items-center gap-8 text-sm">
        <a href="#equipment" class="text-secondary hover:text-primary">Equipment</a>
        <a href="#how-it-works" class="text-secondary hover:text-primary">How It Works</a>
        <a href="#about" class="text-secondary hover:text-primary">About</a>
      </div>
      <a href="#contact" class="text-sm font-medium border border-primary px-4 py-2 hover:bg-primary hover:text-white">
        Get Quote
      </a>
    </div>
  </nav>


  <!-- HERO -->
  <section class="min-h-screen flex items-center pt-16">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-3xl animate-fade-in">
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] mb-8">
          Medical Equipment.<br>Fair Prices.
        </h1>
        <p class="text-xl md:text-2xl text-secondary leading-relaxed mb-10 max-w-2xl">
          New and refurbished medical devices for Nigerian healthcare facilities. Direct from European suppliers and certified manufacturers. No middlemen markup.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#equipment" class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 font-medium hover:bg-secondary">
            View Equipment
          </a>
          <a href="#contact" class="inline-flex items-center justify-center border border-primary px-8 py-4 font-medium hover:bg-surface">
            Request Quote
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- TRUST BAR -->
  <section class="border-y border-light">
    <div class="max-w-6xl mx-auto px-6 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
        <div class="flex items-center gap-3">
          <span class="text-xl">✓</span>
          <span>CE Certified</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xl">✓</span>
          <span>1-Year Warranty</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xl">✓</span>
          <span>NAFDAC Support</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-xl">✓</span>
          <span>24h Response</span>
        </div>
      </div>
    </div>
  </section>


  <!-- WHY FAIRMED -->
  <section class="py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-16">
        <h2 class="font-serif text-3xl md:text-4xl font-bold mb-6">Why FairMed?</h2>
        <p class="text-lg text-secondary leading-relaxed">
          Hospital equipment in Nigeria costs 2–3× what it should. Brokers and distributors stack margins at every step. We source directly from certified European refurbishers and quality manufacturers — passing the savings to you.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-12 md:gap-8">
        <div>
          <p class="font-serif text-4xl font-bold mb-4">20–40%</p>
          <h3 class="font-semibold mb-2">Lower Prices</h3>
          <p class="text-secondary">Direct sourcing eliminates broker markups. Same certified equipment, fair prices.</p>
        </div>
        <div>
          <p class="font-serif text-4xl font-bold mb-4">4+ hrs</p>
          <h3 class="font-semibold mb-2">Battery Backup</h3>
          <p class="text-secondary">LED technology with built-in batteries. Works when the power doesn't.</p>
        </div>
        <div>
          <p class="font-serif text-4xl font-bold mb-4">24 hrs</p>
          <h3 class="font-semibold mb-2">Response Time</h3>
          <p class="text-secondary">WhatsApp support included. Questions answered within a day, not a week.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- EQUIPMENT -->
  <section id="equipment" class="py-24 md:py-32 bg-surface border-y border-light">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mb-16">
        <h2 class="font-serif text-3xl md:text-4xl font-bold mb-6">Equipment</h2>
        <p class="text-lg text-secondary">
          Starting with neonatal care — the highest need, highest impact category. More equipment categories coming soon.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <!-- Product 1 -->
        <div class="bg-white border border-light">
          <div class="aspect-[4/3] bg-neutral-100 flex items-center justify-center border-b border-light">
            <span class="text-muted text-sm">Product Image</span>
          </div>
          <div class="p-6">
            <p class="text-xs text-muted mb-2 uppercase tracking-wide">Neonatal Care</p>
            <h3 class="font-serif text-xl font-semibold mb-3">LED Phototherapy Unit</h3>
            <p class="text-secondary text-sm mb-4">Blue light therapy for neonatal jaundice. LED technology, 4-hour battery backup, digital controls.</p>
            <div class="flex justify-between items-center pt-4 border-t border-light">
              <span class="font-semibold">$1,500 – $2,500</span>
              <a href="#contact" class="text-sm text-muted hover:text-primary">Inquire →</a>
            </div>
          </div>
        </div>

        <!-- Product 2 -->
        <div class="bg-white border border-light">
          <div class="aspect-[4/3] bg-neutral-100 flex items-center justify-center border-b border-light">
            <span class="text-muted text-sm">Product Image</span>
          </div>
          <div class="p-6">
            <p class="text-xs text-muted mb-2 uppercase tracking-wide">Neonatal Care</p>
            <h3 class="font-serif text-xl font-semibold mb-3">Infant Radiant Warmer</h3>
            <p class="text-secondary text-sm mb-4">Temperature-controlled warming for newborns. Digital display, alarm system, servo mode.</p>
            <div class="flex justify-between items-center pt-4 border-t border-light">
              <span class="font-semibold">$3,000 – $5,000</span>
              <a href="#contact" class="text-sm text-muted hover:text-primary">Inquire →</a>
            </div>
          </div>
        </div>

        <!-- Product 3 -->
        <div class="bg-white border border-light">
          <div class="aspect-[4/3] bg-neutral-100 flex items-center justify-center border-b border-light">
            <span class="text-muted text-sm">Product Image</span>
          </div>
          <div class="p-6">
            <p class="text-xs text-muted mb-2 uppercase tracking-wide">Neonatal Care</p>
            <h3 class="font-serif text-xl font-semibold mb-3">Resuscitation Kit</h3>
            <p class="text-secondary text-sm mb-4">Complete newborn resuscitation set. Self-inflating bag, masks (sizes 0 & 1), suction device.</p>
            <div class="flex justify-between items-center pt-4 border-t border-light">
              <span class="font-semibold">$150 – $300</span>
              <a href="#contact" class="text-sm text-muted hover:text-primary">Inquire →</a>
            </div>
          </div>
        </div>

      </div>

      <div class="mt-12 pt-8 border-t border-light">
        <p class="text-secondary">
          <span class="font-medium text-text">Looking for something else?</span> Patient monitors, ECG machines, ultrasound equipment, infusion pumps — we can source it. <a href="#contact" class="underline hover:text-primary">Tell us what you need.</a>
        </p>
      </div>
    </div>
  </section>


  <!-- HOW IT WORKS -->
  <section id="how-it-works" class="py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-16">How It Works</h2>

      <div class="grid md:grid-cols-2 gap-12 md:gap-16">
        <div class="space-y-12">
          <div>
            <p class="font-serif text-4xl font-bold text-muted mb-4">01</p>
            <h3 class="font-semibold text-lg mb-2">Share your requirements</h3>
            <p class="text-secondary">Equipment type, specifications, quantity, timeline. We speak your language — clinical specs, not sales jargon.</p>
          </div>
          <div>
            <p class="font-serif text-4xl font-bold text-muted mb-4">02</p>
            <h3 class="font-semibold text-lg mb-2">Receive your quote</h3>
            <p class="text-secondary">Within 24 hours: detailed specs, CE documentation, unit pricing, and delivery estimate to your facility.</p>
          </div>
        </div>
        <div class="space-y-12">
          <div>
            <p class="font-serif text-4xl font-bold text-muted mb-4">03</p>
            <h3 class="font-semibold text-lg mb-2">Review at your pace</h3>
            <p class="text-secondary">Compare with other suppliers. Ask questions. Request alternatives. No pressure — we're here when you're ready.</p>
          </div>
          <div>
            <p class="font-serif text-4xl font-bold text-muted mb-4">04</p>
            <h3 class="font-semibold text-lg mb-2">We handle logistics</h3>
            <p class="text-secondary">Export documentation, NAFDAC paperwork, shipping coordination. You receive certified equipment, ready to use.</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ABOUT -->
  <section id="about" class="py-24 md:py-32 bg-surface border-y border-light">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <h2 class="font-serif text-3xl md:text-4xl font-bold mb-6">About FairMed</h2>
          <div class="space-y-4 text-secondary leading-relaxed">
            <p>
              FairMed International was founded on a simple observation: hospitals in Nigeria pay too much for equipment they desperately need.
            </p>
            <p>
              The current system is broken. Devices pass through multiple intermediaries — brokers, regional distributors, local agents — each adding their margin. By the time equipment reaches a hospital, it costs 2–3× the original price.
            </p>
            <p>
              We cut through that. We work directly with certified European refurbishers and quality manufacturers who test, calibrate, and certify every device. We handle the logistics, documentation, and NAFDAC registration support. You get professional equipment at fair prices.
            </p>
          </div>
        </div>
        <div class="space-y-8">
          <div>
            <h3 class="font-semibold mb-2">What "Refurbished" Means</h3>
            <p class="text-secondary">
              Professionally inspected, repaired, tested, and certified. Every device includes calibration certificates, maintenance records, and original documentation. CE-marked. ISO 13485 compliant suppliers.
            </p>
          </div>
          <div>
            <h3 class="font-semibold mb-2">Our Guarantee</h3>
            <p class="text-secondary">
              1-year warranty on all equipment. If something goes wrong, we fix it or replace it. 3-year lamp replacement guarantee on phototherapy units. 24-hour WhatsApp support.
            </p>
          </div>
          <div>
            <h3 class="font-semibold mb-2">NAFDAC & Import Support</h3>
            <p class="text-secondary">
              We provide all documentation required for NAFDAC registration and customs clearance. CE certificates, calibration reports, proforma invoices, certificates of origin — everything you need.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- CONTACT -->
  <section id="contact" class="py-24 md:py-32 bg-primary text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">

        <!-- Contact Form -->
        <div>
          <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">Ready to equip your facility?</h2>
          <p class="text-white/70 mb-8">Tell us what you need. We respond within 24 hours.</p>

          <form action="https://formspree.io/f/mqejwvgk" method="POST" class="space-y-4">
            <div>
              <label for="name" class="block text-sm text-white/70 mb-1">Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-white/50">
            </div>
            <div>
              <label for="email" class="block text-sm text-white/70 mb-1">Email *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-white/50">
            </div>
            <div>
              <label for="facility" class="block text-sm text-white/70 mb-1">Facility Name</label>
              <input type="text" id="facility" name="facility" class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-white/50">
            </div>
            <div>
              <label for="message" class="block text-sm text-white/70 mb-1">Equipment Needed *</label>
              <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 bg-white/10 border border-white/20 text-white placeholder-white/40 focus:outline-none focus:border-white/50 resize-none"></textarea>
            </div>
            <button type="submit" class="w-full bg-white text-primary px-6 py-4 font-medium hover:bg-white/90">
              Send Inquiry
            </button>
          </form>
        </div>

        <!-- Direct Contact -->
        <div class="flex flex-col justify-center">
          <p class="text-sm text-white/50 mb-8 uppercase tracking-wide">Or contact us directly</p>

          <div class="space-y-8">
            <div>
              <p class="text-sm text-white/50 mb-2">WhatsApp</p>
              <p class="text-2xl font-serif">+49 151 6148 8385</p>
              <a href="https://wa.me/4915161488385?text=Hi%2C%20I'm%20inquiring%20about%20medical%20equipment%20for%20my%20facility." class="inline-block mt-2 text-sm text-white/70 underline hover:text-white">
                Chat on WhatsApp →
              </a>
            </div>
            <div>
              <p class="text-sm text-white/50 mb-2">Email</p>
              <p class="text-2xl font-serif">info@fairmedinternational.com</p>
              <a href="mailto:info@fairmedinternational.com" class="inline-block mt-2 text-sm text-white/70 underline hover:text-white">
                Send Email →
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- FOOTER -->
  <footer class="border-t border-light py-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-4 gap-8 mb-12">
        <div>
          <p class="font-serif font-bold text-lg mb-4">FairMed International</p>
          <p class="text-sm text-secondary">
            New and refurbished medical equipment for African healthcare facilities.
          </p>
        </div>
        <div>
          <p class="font-semibold text-sm mb-4">Equipment</p>
          <ul class="space-y-2 text-sm text-secondary">
            <li><a href="#equipment" class="hover:text-primary">Neonatal Care</a></li>
            <li><a href="#equipment" class="hover:text-primary">Patient Monitoring</a></li>
            <li><a href="#equipment" class="hover:text-primary">Diagnostics</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-sm mb-4">Company</p>
          <ul class="space-y-2 text-sm text-secondary">
            <li><a href="#about" class="hover:text-primary">About Us</a></li>
            <li><a href="#how-it-works" class="hover:text-primary">How It Works</a></li>
            <li><a href="#contact" class="hover:text-primary">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="font-semibold text-sm mb-4">Contact</p>
          <ul class="space-y-2 text-sm text-secondary">
            <li>WhatsApp: +49 151 6148 8385</li>
            <li>info@fairmedinternational.com</li>
          </ul>
        </div>
      </div>
      <div class="pt-8 border-t border-light flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-muted">
        <p>© 2025 FairMed International. All rights reserved.</p>
      </div>
    </div>
  </footer>

</Layout>
